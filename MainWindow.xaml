<Window x:Class="SPWPFHomework.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SPWPFHomework"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel>
        <TextBlock Text="Прості числа. Введіть нижню межу:"/>
        <TextBox x:Name="BottomTextBox" Width="200"/>
        
        <TextBlock Text="Введіть верхню межу:"/>
        <TextBox x:Name="TopTextBox" Width="200"/>

        <TextBlock Text="Числа Фібоначчі. Введіть число:"/>
        <TextBox x:Name="FibonacciTextBox" Width="200"/>

        <TextBlock Text="Лог роботи:"></TextBlock>
        <TextBox x:Name="LoggerTextBox" Width="500" Height="50"></TextBox>

        <TextBlock Text="Лог виконання:"/>

        <Grid>
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <TextBox x:Name="PrimeLoggerTextBox"
             Width="300"
             Height="150"
             IsReadOnly="True"
             Margin="0,10,15,10"/>

                <TextBox x:Name="FibonacciLoggerTextBox"
             Width="300"
             Height="150"
             IsReadOnly="True"/>
            </StackPanel>
        </Grid>

        <Button x:Name="ExecuteButton" Click="ExecuteButton_OnClick">Обчислити</Button>
        <Button x:Name="StopPrimeButton" Click="StopPrimeButton_OnClick">Зупинити потік для простих чисел</Button>
        <Button x:Name="StopFibonacciButton" Click="StopFibonacciButton_OnClick">Зупинити потік для чисел фібоначчі</Button>
        <Button x:Name="PausePrimeButton" Click="PausePrimeButton_OnClick">Пауза потоку для простих чисел</Button>
        <Button x:Name="PauseFibonacciButton" Click="PauseFibonacciButton_OnClick">Пауза потоку для чисел фібоначчі</Button>
        <Button x:Name="ResumePrimeButton" Click="ResumePrimeButton_OnClick">Відновити потік для простих чисел</Button>
        <Button x:Name="ResumeFibonacciButton" Click="ResumeFibonacciButton_OnClick">Відновити потік для чисел фібоначчі</Button>
        <Button x:Name="RestartButton" Click="RestartButton_OnClick">Перезапустити потоки</Button>
        
    </StackPanel>
</Window>
