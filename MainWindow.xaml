<Window x:Class="SPWPFHomework.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SPWPFHomework"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel>
        <TextBlock Text="Прості числа. Введіть нижню межу:"/>
        <TextBox x:Name="BottomTextBox" Width="200"/>
        
        <TextBlock Text="Введіть верхню межу:"/>
        <TextBox x:Name="TopTextBox" Width="200"/>

        <TextBlock Text="Числа Фібоначчі. Введіть число:"/>
        <TextBox x:Name="PrimeTextBox" Width="200"/>

        <TextBlock Text="Лог виконання:"/>
        <TextBox x:Name="LoggerTextBox"
             Width="300"
             Height="150"
             IsReadOnly="True"/>

        <Button x:Name="ExecuteButton" Click="ExecuteButton_OnClick">Обчислити</Button>
    </StackPanel>
</Window>
